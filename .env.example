# ═══════════════════════════════════════════════════════════════════
#  YASCO ERP — Environment Variables Reference
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── App Identity ─────────────────────────────────────────────────────
APP_NAME=YASCO ERP
APP_VERSION=1.0.0
NODE_ENV=production

# ── Auth / OAuth (REQUIRED) ──────────────────────────────────────────
# Kimi platform credentials — get from your Kimi developer console
APP_ID=your_app_id_here
APP_SECRET=your_app_secret_here_minimum_32_chars
KIMI_AUTH_URL=https://auth.kimi.ai
KIMI_OPEN_URL=https://open.kimi.ai
OWNER_UNION_ID=your_owner_union_id

# ── Admin Account ────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2025!
ADMIN_EMAIL=admin@yourcompany.com

# ── Database (REQUIRED) ──────────────────────────────────────────────
# PlanetScale, MySQL 8+, or any mysql2-compatible database
DATABASE_URL=mysql://user:password@host:3306/yasco_erp?ssl={"rejectUnauthorized":true}
# Optional: Read replica for reporting (better performance)
DATABASE_REPLICA_URL=mysql://user:password@replica-host:3306/yasco_erp?ssl={"rejectUnauthorized":true}

# ── Server ───────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── Security / Encryption ────────────────────────────────────────────
# MUST be exactly 32 characters for AES-256 encryption
ENCRYPTION_KEY=your-32-character-encryption-key!

# ── Email / SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourcompany.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourcompany.com
SMTP_SECURE=false

# ── AWS S3 / File Storage ────────────────────────────────────────────
# For logos, invoice PDFs, product images, employee photos
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=me-south-1
S3_BUCKET=yasco-erp-files

# ── AI Assistant ─────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Monitoring (Optional but recommended) ────────────────────────────
# Sign up at sentry.io
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Redis Cache (Optional but recommended for scale) ─────────────────
# Upstash, Redis Cloud, or self-hosted Redis
REDIS_URL=redis://default:password@host:6379

# ── Desktop License (Desktop app only) ───────────────────────────────
# Automatically set by Tauri — do NOT set manually
# ERP_DESKTOP_MODE=true

# ── SMS (REQUIRED for SMS notifications) ─────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+966500000000

# ── WhatsApp Business API (Optional) ─────────────────────────────────────
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ── Voice Calls (Optional — Twilio Voice) ────────────────────────────────
VOICE_TWILIO_ACCOUNT_SID=your_voice_twilio_sid
VOICE_TWILIO_AUTH_TOKEN=your_voice_twilio_token
VOICE_TWILIO_PHONE_NUMBER=+966500000001

# ── IoT / MQTT (Optional) ───────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://broker.yourcompany.com:1883
MQTT_USERNAME=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password

# ── Feature Flags ────────────────────────────────────────────────────
ENABLE_BULK_EMAIL=false
MAX_UPLOAD_MB=50

# ═══════════════════════════════════════════════════════════════════
#  SAUDI ARABIA (ZATCA) — No extra env needed
#  ZATCA credentials are stored per-tenant in the database (encrypted)
# ═══════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════
#  DEPLOYMENT NOTES
# ═══════════════════════════════════════════════════════════════════
# Web / SaaS:  npm run build && npm run start
# Desktop:     npm run build:tauri  (produces .exe for Windows)
# DB Migration: npm run db:migrate
# DB Studio:   npm run db:studio
