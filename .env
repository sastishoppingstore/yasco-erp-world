# ── Backend ─────────────────────────────────────────────────────
APP_ID=demo_app
APP_SECRET=demo_secret_key_for_jwt_signing

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=mysql://erp:erp123@localhost:3306/erp

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_KIMI_AUTH_URL=https://auth.kimi.com
