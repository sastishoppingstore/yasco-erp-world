# ── Backend ─────────────────────────────────────────────────────
APP_ID=erp_prod_app
APP_SECRET=your_app_secret_here

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=mysql://erp_user:password@localhost:3306/erp_yasco_prod

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_APP_ID=erp_prod_app

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=wafaweb_admin
ADMIN_USERNAME=wafaweb
ADMIN_PASSWORD=Wafa@1122
ADMIN_EMAIL=admin@waftch.com

# ── AI / Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── SMTP (Email OTP) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
SMTP_SECURE=false

NODE_ENV=production
