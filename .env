# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=demo_admin

# ── AI / Gemini ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

NODE_ENV=production
