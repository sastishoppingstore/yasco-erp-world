{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "YASCO ERP",
  "version": "1.0.0",
  "identifier": "com.yasco.erp",
  "build": {
    "frontendDist": "../dist/public",
    "devUrl": "http://127.0.0.1:32145/app",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "YASCO ERP",
        "url": "http://127.0.0.1:32145/app",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/node"
    ],
    "resources": {
      "resources/package.json": "package.json",
      "../dist/boot.js": "dist/boot.js",
      "../dist/public": "dist/public"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "YASCO Enterprise Resource Planning System",
    "longDescription": "World-class ERP with Saudi ZATCA compliance, multi-country support, and full offline desktop capabilities.",
    "category": "Business",
    "copyright": "© 2025 YASCO. All rights reserved.",
    "publisher": "YASCO Technologies",
    "nsis": {
      "installMode": "currentUser"
    }
}
