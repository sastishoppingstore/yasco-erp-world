import { useState } from "react";
import { useNavigate } from "react-router";
import { trpc } from "@/providers/trpc";
import { useAuthStore } from "@/stores/authStore";
import { Button } from "@/components/ui/button";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Input } from "@/components/ui/input";
import { ArrowLeft } from "lucide-react";

export default function Impersonate() {
  const navigate = useNavigate();
  const { setUser, setToken } = useAuthStore();
  const [tenantId, setTenantId] = useState("");
  const impersonate = trpc.superAdmin.companies.impersonate.useMutation();

  const handleImpersonate = async () => {
    if (!tenantId) return;
    const result = await impersonate.mutateAsync({ tenantId: Number(tenantId) });
    if (result.token && result.user) {
      setToken(result.token);
      setUser(result.user);
      navigate("/app/dashboard");
    }
  };

  return (
    <div className="p-6 max-w-md mx-auto">
      <Button variant="ghost" onClick={() => navigate(-1)} className="mb-4">
        <ArrowLeft className="w-4 h-4 mr-2" /> Back
      </Button>
      <Card>
        <CardHeader>
          <CardTitle>Impersonate Client</CardTitle>
        </CardHeader>
        <CardContent className="space-y-4">
          <Input
            placeholder="Tenant ID"
            value={tenantId}
            onChange={(e) => setTenantId(e.target.value)}
          />
          <Button onClick={handleImpersonate} disabled={!tenantId} className="w-full">
            Login as Client Admin
          </Button>
          <p className="text-xs text-muted-foreground">
            This action is logged in audit trail.
          </p>
        </CardContent>
      </Card>
    </div>
  );
}
